# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# SUPABASE_URL: Sua URL do projeto Supabase
SUPABASE_URL="https://your-project.supabase.co"

# SUPABASE_ANON_KEY: Sua chave anon do Supabase
SUPABASE_ANON_KEY="your-anon-key"

# SERPER_API_KEY: Para o módulo Google Maps (Serper.dev)
SERPER_API_KEY="sua-chave-serper"

# PROXY (Anti-Detecção - Standby)
PROXY_ENABLED=false
# PROXY_SERVER=http://proxy.example.com:8080
# PROXY_USERNAME=seu_usuario
# PROXY_PASSWORD=sua_senha

# GITHUB_TOKEN: Token de Acesso Pessoal do GitHub (necessário se o repositório for privado)
GITHUB_TOKEN=""

